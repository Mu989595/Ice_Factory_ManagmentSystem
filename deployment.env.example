# Copy these to Azure App Service → Configuration → Application settings
# (Use double underscore __ for nested JSON keys)

ASPNETCORE_ENVIRONMENT=Production

ConnectionStrings__DefaultConnection=Server=tcp:YOUR-SERVER.database.windows.net,1433;Initial Catalog=IceFactoryDB;User ID=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

JwtSettings__Secret=REPLACE_WITH_NEW_LONG_RANDOM_SECRET
JwtSettings__Issuer=IceFactoryApp
JwtSettings__Audience=IceFactoryUsers
JwtSettings__ExpirationInMinutes=1440

# Frontend URL(s) — option A: indexed keys
Cors__AllowedOrigins__0=https://your-frontend-domain.com

# Frontend URL(s) — option B: comma-separated
# Cors__AllowedOriginsCsv=https://your-frontend.vercel.app,https://www.your-frontend.com
